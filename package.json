{
  "name": "katachiya",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:page": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "typecheck": "npm run typecheck:app && npm run typecheck:tooling && npm run typecheck:supabase",
    "typecheck:app": "tsc --noEmit -p tsconfig.app.strict.json && tsc --noEmit -p tsconfig.app.json",
    "typecheck:tooling": "tsc --noEmit -p tsconfig.tooling.json",
    "typecheck:supabase": "tsc --noEmit -p tsconfig.supabase.json",
    "format": "prettier --write \"src/**/*.{js,jsx}\" \"e2e/**/*.js\" \"scripts/**/*.js\" \"supabase/functions/**/*.ts\" \"*.{js,jsx,ts}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx}\" \"e2e/**/*.js\" \"scripts/**/*.js\" \"supabase/functions/**/*.ts\" \"*.{js,jsx,ts}\"",
    "vocab:build": "node scripts/build-verb-lexicon.js",
    "sentences:batches": "node scripts/build-sentence-batches.js",
    "sentences:english": "node scripts/rewrite-sentence-english.js",
    "sentences:import": "node scripts/import-sentence-library.js",
    "size": "node scripts/check-bundle-size.js",
    "ci:fast": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "ci": "npm run ci:fast && npm run test:e2e && npm run build && npm run size",
    "prepare": "node -e \"try{require('child_process').execSync('git config core.hooksPath .githooks')}catch(e){}\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "kuromoji": "^0.1.2",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}
