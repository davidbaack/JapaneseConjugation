{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "noImplicitAny": false,
    "types": ["node"]
  },
  "include": ["*.config.js", "eslint.config.js", "e2e/**/*.js", "scripts/**/*.js"],
  "exclude": ["node_modules", "dist", "test-results"]
}
