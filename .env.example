# Supabase enables cloud sync and the default Gemini proxy.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Local development fallback only. Production Gemini calls should use the
# Supabase Edge Function with a server-side GEMINI_API_KEY secret.
VITE_GEMINI_API_KEY=your-gemini-api-key

# Supabase Edge Function secrets, set with `supabase secrets set`:
# GEMINI_API_KEY=your-gemini-api-key
# ALLOWED_ORIGIN=https://your-domain.example
